# Repository-level ignores. Each app (web/, server/) also has its own .gitignore.

# Dependencies
node_modules/

# Build / coverage artifacts
dist/
coverage/
*.tsbuildinfo

# Playwright
test-results/
playwright-report/
blob-report/

# Environment files (keep the committed examples)
.env
.env.*
!.env.example

# OS / editor
.DS_Store
.idea
.vscode/*
!.vscode/extensions.json

# Logs
*.log

# Private planning doc (not part of the public project)
documentacao-exemplo.md
